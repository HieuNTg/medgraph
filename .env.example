# MEDGRAPH - Drug Interaction Cascade Analyzer
# Copy to .env and adjust as needed

# Server
MEDGRAPH_HOST=127.0.0.1
MEDGRAPH_PORT=8000

# Database
MEDGRAPH_DB_PATH=data/medgraph.db

# OpenFDA API (optional - no key needed for <240 req/min)
OPENFDA_CACHE_DIR=data/openfda_cache
SKIP_OPENFDA=true

# DrugBank (optional - place CSV files in this directory)
DRUGBANK_DIR=data/drugbank

# Frontend dev server
VITE_API_URL=http://localhost:8000
